  DEFINES = -DVMP_ARCH_STR=\"x64\" -DVMP_PLATFORM_STR=\"linux\" -DVMP_WITH_JIT=1 -DVMP_WITH_VM2=1
  DEP_FILE = tests/CMakeFiles/audit_cpp_format.dir/audit/audit_cpp_format.cpp.o.d
  FLAGS = -std=gnu++17
  INCLUDES = -I/workspace/vmp/runtime/audit/include -I/workspace/vmp/policy/include
  OBJECT_DIR = tests/CMakeFiles/audit_cpp_format.dir
  OBJECT_FILE_DIR = tests/CMakeFiles/audit_cpp_format.dir/audit


# =============================================================================
# Link build statements for EXECUTABLE target audit_cpp_format


#############################################
# Link the executable tests/audit_cpp_format

build tests/audit_cpp_format: CXX_EXECUTABLE_LINKER__audit_cpp_format_ tests/CMakeFiles/audit_cpp_format.dir/audit/audit_cpp_format.cpp.o | runtime/audit/libvmp_runtime_audit.a policy/libvmp_policy.a || policy/libvmp_policy.a runtime/audit/libvmp_runtime_audit.a
  LINK_LIBRARIES = runtime/audit/libvmp_runtime_audit.a  policy/libvmp_policy.a
  OBJECT_DIR = tests/CMakeFiles/audit_cpp_format.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_FILE = tests/audit_cpp_format
  TARGET_PDB = audit_cpp_format.dbg


#############################################
# Utility command for test

build tests/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /workspace/vmp/build/tests && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build tests/test: phony tests/CMakeFiles/test.util


#############################################
# Utility command for edit_cache

build tests/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /workspace/vmp/build/tests && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build tests/edit_cache: phony tests/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build tests/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /workspace/vmp/build/tests && /usr/bin/cmake --regenerate-during-build -S/workspace/vmp -B/workspace/vmp/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build tests/rebuild_cache: phony tests/CMakeFiles/rebuild_cache.util

