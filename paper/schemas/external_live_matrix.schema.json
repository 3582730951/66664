{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pavmp/external_live_matrix.schema.json",
  "title": "PAVMP external live evidence matrix",
  "description": "Submission-safe schema for optional external Frida/ptrace/DBI/emulator evidence. Reports validated by this schema are evidence inputs only; they do not automatically expand paper claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generated_utc",
    "fabricated_data",
    "paper_claims_mutated",
    "runner",
    "target",
    "checks",
    "ok",
    "limitations"
  ],
  "properties": {
    "schema": {
      "const": "pavmp.external_live_matrix.v1"
    },
    "generated_utc": {
      "type": "string",
      "description": "UTC ISO-8601 timestamp, e.g. 2026-04-24T12:34:56Z."
    },
    "fabricated_data": {
      "const": false
    },
    "paper_claims_mutated": {
      "const": false,
      "description": "External reports may supplement the artifact, but they must not silently mutate paper claims or tables."
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "arch",
        "kernel_or_build",
        "ptrace_or_debug_policy",
        "tool_versions"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 2
        },
        "arch": {
          "type": "string",
          "minLength": 2
        },
        "kernel_or_build": {
          "type": "string",
          "minLength": 2
        },
        "ptrace_or_debug_policy": {
          "type": "string",
          "minLength": 2
        },
        "tool_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "minProperties": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binary",
        "sha256",
        "iterations",
        "expected_result"
      ],
      "properties": {
        "binary": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "iterations": {
          "type": "integer",
          "minimum": 1
        },
        "expected_result": {
          "type": [
            "string",
            "integer"
          ]
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "ok": {
      "type": "boolean"
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "skipped_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_alias",
        "category",
        "tool",
        "command_summary",
        "ok",
        "oracle_triggered",
        "output_policy",
        "audit_events",
        "audit_excerpt",
        "claim_scope",
        "non_claims",
        "limitations"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_.-]+$"
        },
        "display_alias": {
          "type": "string",
          "minLength": 2
        },
        "category": {
          "enum": [
            "frida",
            "ptrace",
            "dbi",
            "emulator",
            "debugger",
            "mapping_integrity",
            "platform"
          ]
        },
        "tool": {
          "type": "string",
          "minLength": 2
        },
        "command_summary": {
          "type": "string",
          "minLength": 4
        },
        "ok": {
          "type": "boolean"
        },
        "oracle_triggered": {
          "type": "boolean"
        },
        "output_policy": {
          "enum": [
            "preserve_expected_output",
            "configured_reaction_path",
            "audit_only"
          ]
        },
        "observed_result": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "expected_result": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "output_correct": {
          "type": "boolean"
        },
        "configured_reaction_observed": {
          "type": "boolean"
        },
        "audit_events": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "audit_excerpt": {
          "type": "string",
          "maxLength": 2000
        },
        "evidence_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "kind",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 2
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-fA-F]{64}$"
              }
            }
          }
        },
        "claim_scope": {
          "type": "string",
          "minLength": 12
        },
        "non_claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    }
  }
}
